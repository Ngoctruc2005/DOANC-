<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Quản trị Vĩnh Khánh</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

    <style>
            body {
                display: flex;
                min-height: 100vh;
                background: #f4f6f9;
            }

            .sidebar {
                width: 250px;
                background: #1e293b;
                color: white;
            }

                .sidebar a {
                    color: #cbd5e1;
                    display: block;
                    padding: 12px 20px;
                    text-decoration: none;
                }

                    .sidebar a:hover {
                        background: #334155;
                        color: #fff;
                    }

            .content {
                flex: 1;
                padding: 20px;
            }

            .topbar {
                background: white;
                padding: 10px 20px;
                margin-bottom: 20px;
                border-bottom: 1px solid #ddd;
            }
    </style>
</head>

<body>

    <!-- Sidebar -->
    <div class="sidebar">
        <h4 class="text-center py-3">🍜 Vĩnh Khánh</h4>

        <a href="/Admin/Index"><i class="fa fa-chart-line"></i> Bảng điều khiển</a>
        <a href="/Admin/Restaurants"><i class="fa fa-store"></i> Quán ăn</a>
        <a href="/POIs/Index"><i class="fa fa-map"></i> Điểm tham quan</a>
        <a href="/Admin/PendingPOIs"><i class="fa fa-clock"></i> Chờ duyệt</a>
        <a href="/Admin/ApprovedPOIs"><i class="fa fa-check"></i> Đã duyệt</a>
        <a href="/Admin/OwnerRequests"><i class="fa fa-user"></i> Yêu cầu chủ quán</a>

        <a href="/Auth/Login"><i class="fa fa-sign-out"></i> Đăng xuất</a>
    </div>

    <!-- Content -->
    <div class="content">
        <!-- Topbar -->
        <div class="topbar d-flex justify-content-between">
            <h5>@ViewData["Title"]</h5>
            <div>
                🔔 Quản trị viên
            </div>
        </div>

        @RenderBody()
    </div>

</body>
</html>