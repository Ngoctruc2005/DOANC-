<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Quản trị Vĩnh Khánh</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

    <style>
            body {
                display: flex;
                min-height: 100vh;
                background: #f4f6f9;
            }

            .sidebar {
                width: 250px;
                background: #1e293b;
                color: white;
            }

                .sidebar a {
                    color: #cbd5e1;
                    display: block;
                    padding: 12px 20px;
                    text-decoration: none;
                }

                    .sidebar a:hover {
                        background: #334155;
                        color: #fff;
                    }

            .content {
                flex: 1;
                padding: 20px;
            }

            .topbar {
                background: white;
                padding: 10px 20px;
                margin-bottom: 20px;
                border-bottom: 1px solid #ddd;
            }
    </style>
</head>

<body>

    <!-- Sidebar -->
    <div class="sidebar">
        <h4 class="text-center py-3"><i class="fa fa-bowl-food text-warning me-2"></i>Vĩnh Khánh</h4>

        <a href="/Admin/Index"><i class="fa fa-chart-line"></i> Bảng điều khiển</a>
        <a href="/Admin/OwnerRequests"><i class="fa fa-users-cog"></i> Duyệt chủ quán</a>
        <a href="/Admin/Owners"><i class="fa fa-user-tie"></i> Chủ quán</a>
        <a href="/POIs/Index"><i class="fa fa-store"></i> Quán ăn</a>
        <a href="/POIs/Pending"><i class="fa fa-clock"></i> Chờ duyệt</a>
        <!-- VisitHistory link removed as per request -->
        <a href="/Admin/Cancelled"><i class="fa fa-ban"></i> Đã hủy</a>
        <a href="/Admin/Deleted"><i class="fa fa-trash"></i> Đã xóa</a>

        <a href="/Auth/Logout"><i class="fa fa-sign-out"></i> Đăng xuất</a>
    </div>

    <!-- Content -->
    <div class="content">
        <!-- Topbar -->
        <div class="topbar d-flex justify-content-between">
            <h5>@ViewData["Title"]</h5>
            <div>
                <i class="fa fa-bell text-warning me-1"></i>Quản trị viên
            </div>
        </div>

        @RenderBody()
    </div>

    <!-- Bootstrap and other necessary scripts could be here -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

