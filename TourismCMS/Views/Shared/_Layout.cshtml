<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - V&#297;nh Kh&#225;nh</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        body { font-family: 'Segoe UI', Roboto, 'Noto Sans', Arial, sans-serif; }
        .sidebar { background-color: #1e293b; font-family: inherit; }
        .sidebar a { color: #cbd5e1; text-decoration: none; padding: 12px 20px; display: block; border-radius: 5px; margin-bottom: 5px; font-weight: 500; font-size: 15px;}
        .sidebar a:hover { background-color: #334155; color: #ffffff; text-decoration: none; }
        .sidebar a i { width: 30px; text-align: center; }
        .sidebar-logo {
            font-size: 24px;
            font-weight: bold;
        }
    </style>
</head>
<body>

    <div class="d-flex">

        @await Html.PartialAsync("_Sidebar")

        <!-- Content -->
        <div class="p-4 w-100">

            @if (User.Identity.IsAuthenticated)
            {
                <!-- Header -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3>H&#7879; th&#7889;ng qu&#7843;n l&#253; &#7849;m th&#7921;c</h3>
                    <div>
                        <div class="dropdown">
                            <button class="btn btn-outline-secondary dropdown-toggle" type="button" id="userMenu" data-bs-toggle="dropdown" aria-expanded="false">
                                <b>@User.Identity.Name</b>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenu">
                                <li><a class="dropdown-item" href="/Auth/Logout"><i class="fa fa-sign-out-alt"></i> &#272;&#259;ng xu&#7845;t</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            }

            @RenderBody()
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

