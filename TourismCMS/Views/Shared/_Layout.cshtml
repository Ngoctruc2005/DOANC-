<!DOCTYPE html>
<html>
<head>
    <title>Tourism Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

    <div class="d-flex">

        <!-- Sidebar -->
        <div class="bg-dark text-white p-3" style="width:250px; min-height:100vh;">
            <h4>🍜 Vinh Khanh</h4>
            <hr />

            <p class="text-muted">ADMIN</p>
            <a href="/Admin/Index" class="text-white d-block mb-2">📊 Dashboard</a>
            <a href="/Admin/Restaurants" class="text-white d-block mb-2">🏪 Quản lý quán</a>
            <a href="/Admin/PendingPOIs" class="text-white d-block mb-2">⏳ Duyệt quán</a>

            <hr />

            <p class="text-muted">OWNER</p>
            <a href="/Owner/Index" class="text-white d-block mb-2">🏠 Dashboard</a>
            <a href="/Owner/MyRestaurants" class="text-white d-block mb-2">🍽 Quán của tôi</a>
        </div>

        <!-- Content -->
        <div class="p-4 w-100">

            <!-- Header -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3>Hệ thống quản lý ẩm thực</h3>
                <button class="btn btn-outline-danger">Logout</button>
            </div>

            @RenderBody()
        </div>

    </div>

</body>
</html>