<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - V&#297;nh Kh&#225;nh</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        .sidebar { background-color: #1e293b; font-family: sans-serif; }
        .sidebar a { color: #cbd5e1; text-decoration: none; padding: 12px 20px; display: block; border-radius: 5px; margin-bottom: 5px; font-weight: 500; font-size: 15px;}
        .sidebar a:hover { background-color: #334155; color: #ffffff; text-decoration: none; }
        .sidebar a i { width: 30px; text-align: center; }
        .sidebar-logo {
            font-size: 24px;
            font-weight: bold;
        }
    </style>
</head>
<body>

    <div class="d-flex">

        @if (User.Identity.IsAuthenticated)
        {
            <!-- Sidebar -->
            <div class="sidebar text-white p-3" style="width:250px; min-height:100vh;">
                <h4 class="text-center sidebar-logo mb-4 mt-2"><i class="fa fa-bowl-food text-danger pe-2"></i> V&#297;nh Kh&#225;nh</h4>

                @if (User.IsInRole("admin"))
                {
                    <a href="/Admin/Index"><i class="fa fa-chart-line"></i> B&#7843;ng &#273;i&#7873;u khi&#7875;n</a>
                    <a href="/Admin/Registrations"><i class="fa fa-users-cog"></i> Duy&#7879;t ch&#7911; qu&#225;n</a>
                    <a href="/Admin/Owners"><i class="fa fa-user-tie"></i> Ch&#7911; qu&#225;n</a>
                    <a href="/POIs/Index"><i class="fa fa-store"></i> Qu&#225;n &#259;n</a>
                    <a href="/POIs/Pending"><i class="fa fa-clock"></i> Ch&#7901; duy&#7879;t</a>
                    <a href="/Admin/Cancelled"><i class="fa fa-ban"></i> &#272;&#227; h&#7911;y</a>
                    <a href="/Admin/Deleted"><i class="fa fa-trash"></i> &#272;&#227; x&#243;a</a>
                    <a href="/Auth/Logout"><i class="fa fa-sign-out-alt"></i> &#272;&#259;ng xu&#7845;t</a>
                }

                @if (User.IsInRole("poi_owner"))
                {
                    <a href="/Owner/Index"><i class="fa fa-chart-line"></i> B&#7843;ng &#273;i&#7873;u khi&#7875;n</a>
                    <a href="/POIs/Index"><i class="fa fa-store"></i> Qu&#225;n c&#7911;a t&#244;i</a>
                    <a href="/POIs/Create"><i class="fa fa-plus"></i> &#272;&#259;ng k&#253; qu&#225;n</a>
                    <a href="/Auth/Logout"><i class="fa fa-sign-out-alt"></i> &#272;&#259;ng xu&#7845;t</a>
                }
            </div>
        }

        <!-- Content -->
        <div class="p-4 w-100">

            @if (User.Identity.IsAuthenticated)
            {
                <!-- Header -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3>H&#7879; th&#7889;ng qu&#7843;n l&#253; &#7849;m th&#7921;c</h3>
                    <div>
                        <div class="dropdown">
                            <button class="btn btn-outline-secondary dropdown-toggle" type="button" id="userMenu" data-bs-toggle="dropdown" aria-expanded="false">
                                <b>@User.Identity.Name</b>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenu">
                                <li><a class="dropdown-item" href="/Auth/Logout"><i class="fa fa-sign-out-alt"></i> &#272;&#259;ng xu&#7845;t</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            }

            @RenderBody()
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
