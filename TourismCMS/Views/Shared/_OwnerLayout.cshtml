<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Chủ quán Vĩnh Khánh</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

    <style>
        body {
            display: flex;
            min-height: 100vh;
            background: #f4f6f9;
        }

        .sidebar {
            width: 250px;
            background: #1e293b;
            color: white;
        }

        .sidebar a {
            color: #cbd5e1;
            display: block;
            padding: 12px 20px;
            text-decoration: none;
        }

        .sidebar a:hover {
            background: #334155;
            color: #fff;
        }

        .content {
            flex: 1;
            padding: 20px;
        }

        .topbar {
            background: white;
            padding: 10px 20px;
            margin-bottom: 20px;
            border-bottom: 1px solid #ddd;
        }
    </style>
</head>
<body>
    @{ var hideSidebar = (ViewData["HideSidebar"] as bool?) == true; }

    @if (!hideSidebar)
    {
        @await Html.PartialAsync("_Sidebar")
    }

    <div class="content">
        <div class="topbar d-flex justify-content-between">
            <h5>@ViewData["Title"]</h5>
            <div>
                <i class="fa fa-user text-warning me-1"></i>Chủ quán
            </div>
        </div>

        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

