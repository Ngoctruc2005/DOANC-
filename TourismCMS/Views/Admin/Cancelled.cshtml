@model IEnumerable<TourismCMS.Models.POI>
@{
    ViewData["Title"] = "Danh sách đã hủy";
    Layout = "_Layout";
    var cancelledOwners = ViewBag.CancelledOwners as IEnumerable<TourismCMS.Models.OwnerRegistrationViewModel>;
}

<div class="container-fluid mt-4">
    <h2 class="mb-3">Tài khoản chủ quán đã hủy</h2>
    <div class="card shadow-sm mb-4">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-danger">
                    <tr>
                        <th>Mã đăng ký</th>
                        <th>Mã User</th>
                        <th>Họ tên</th>
                        <th>SĐT</th>
                        <th>Tên đăng nhập</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @if (cancelledOwners != null && cancelledOwners.Any())
                    {
                        foreach (var owner in cancelledOwners)
                        {
                            <tr>
                                <td>@owner.RegistrationId</td>
                                <td>@owner.UserId</td>
                                <td>@owner.FullName</td>
                                <td>@owner.PhoneNumber</td>
                                <td>@owner.Username</td>
                            <td><span class="badge bg-danger">Đã hủy</span></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted"><em>Không có tài khoản chủ quán đã hủy.</em></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <h2 class="mb-3">Quán ăn đã hủy</h2>
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-danger">
                    <tr>
                        <th>Mã quán</th>
                        <th>Tên quán</th>
                        <th>Địa chỉ</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var poi in Model)
                        {
                            <tr>
                                <td>@poi.Poiid</td>
                                <td>@poi.Name</td>
                                <td>@poi.Address</td>
                                <td><span class="badge bg-danger">@poi.Status</span></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-4 text-muted"><em>Không có quán ăn đã hủy.</em></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

