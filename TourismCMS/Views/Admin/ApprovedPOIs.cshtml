@model List<POI>

<h2>Quán đã duyệt</h2>

<table class="table table-bordered">
    <tr>
        <th>Tên quán</th>
        <th>Trạng thái</th>
    </tr>

    @foreach (var p in Model)
    {
        <tr>
            <td>@p.Name</td>
            <td>
                <span class="badge bg-success">Approved</span>
            </td>
        </tr>
    }
</table>

