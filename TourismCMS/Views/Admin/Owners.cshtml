@model IEnumerable<TourismCMS.Models.OwnerListItemViewModel>
@{
    ViewData["Title"] = "Danh sách chủ quán";
    Layout = "_Layout";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Danh sách chủ quán đã duyệt</h2>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-primary">
                    <tr>
                        <th>Họ tên</th>
                        <th>SĐT</th>
                        <th>Tên đăng nhập</th>
                        <th>Số quán</th>
                        <th>Chức năng</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var owner in Model)
                        {
                            <tr>
                                <td>
                                    @(string.IsNullOrWhiteSpace(owner.FullName) ? owner.Username : owner.FullName)
                                </td>
                                <td>@owner.PhoneNumber</td>
                                <td>@owner.Username</td>
                                <td>@owner.RestaurantCount</td>
                                <td>
            <a asp-action="OwnerRestaurants" asp-route-id="@owner.UserId" class="btn btn-info btn-sm me-1">Xem quán ăn</a>
                                    <form asp-action="DeleteOwner" method="post" style="display:inline;" onsubmit="return confirm('Báº¡n cÃ³ cháº¯c muá»‘n xÃ³a chá»§ quÃ¡n nÃ y?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@owner.UserId" />
                                        <button type="submit" class="btn btn-danger btn-sm">Xóa</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                                <td colspan="5" class="text-center py-4 text-muted">
                                <em>Chưa có chủ quán nào được duyệt.</em>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

