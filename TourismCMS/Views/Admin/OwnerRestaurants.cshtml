@model IEnumerable<TourismCMS.Models.POI>
@{
    ViewData["Title"] = "Quán ăn của chủ quán";
    Layout = "_Layout";
}

<div class="container-fluid mt-4">
    <h2 class="mb-2">Quán ăn của: @ViewBag.OwnerName</h2>
    <p class="text-muted">SĐT: @ViewBag.OwnerPhone</p>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-primary">
                    <tr>
                        <th>Tên quán</th>
                        <th>Địa chỉ</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var poi in Model)
                        {
                            var displayStatus = poi.Status == "Ch? duy?t" ? "Chờ duyệt" : poi.Status;
                            <tr>
                                <td>@poi.Name</td>
                                <td>@poi.Address</td>
                                <td>@displayStatus</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center py-4 text-muted">
                                <em>Chủ quán này chưa có quán ăn nào.</em>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Owners" class="btn btn-secondary">Quay lại danh sách chủ quán</a>
    </div>
</div>
