@model List<TourismCMS.Models.DeviceItemViewModel>

<div class="card mb-3">
    <div class="card-body">
        <h6>Tất cả thiết bị (@((Model?.Count) ?? 0))</h6>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Tên thiết bị</th>
                        <th class="text-end">Lần truy cập cuối</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model == null || Model.Count == 0)
                {
                    <tr><td colspan="2" class="text-center text-muted">Không có dữ liệu</td></tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-break" style="min-width:220px;">
                                <div class="fw-semibold">
                                    <a asp-action="DeviceDetails" asp-controller="Admin" asp-route-id="@System.Net.WebUtility.UrlEncode(item.DeviceId ?? string.Empty)">
                                        @Html.Raw(System.Net.WebUtility.HtmlEncode(item.AgentSample ?? "-"))
                                    </a>
                                </div>
                                <div class="text-muted small mt-1"><code>@Html.Raw(System.Net.WebUtility.HtmlEncode(item.DeviceId ?? "-"))</code></div>
                            </td>
                            <td class="text-end text-truncate">@(item.LastSeen?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>