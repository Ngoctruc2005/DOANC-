п»ҝ@model IEnumerable<TourismCMS.Models.OwnerRegistrationViewModel>
@{
    ViewData["Title"] = "PhГғВӘ duyГЎВ»вҖЎt chГЎВ»В§ quГғВЎn";
    Layout = "_Layout";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Danh sГғВЎch Г„вҖҳГ„Ж’ng kГғВҪ chГЎВ»В§ quГғВЎn chГЎВ»Вқ duyГЎВ»вҖЎt</h2>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-primary">
                    <tr>
                        <th>MГғВЈ Г„вҖҳГ„Ж’ng kГғВҪ</th>
                        <th>MГғВЈ User</th>
                        <th>HГЎВ»ВҚ tГғВӘn</th>
                        <th>SГ„ВҗT</th>
                        <th>TГғВӘn Г„вҖҳГ„Ж’ng nhГЎВәВӯp</th>
                        <th>TrГЎВәВЎng thГғВЎi</th>
                        <th class="text-center">Thao tГғВЎc</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.RegistrationId</td>
                                <td>@item.UserId</td>
                                <td>@item.FullName</td>
                                <td>@item.PhoneNumber</td>
                                <td>@item.Username</td>
                                <td>
                                    <span class="badge bg-warning text-dark">
                                        @(string.Equals(item.Status, "pending", StringComparison.OrdinalIgnoreCase) ? "ChГЎВ»Вқ duyГЎВ»вҖЎt" : item.Status)
                                    </span>
                                </td>
                                <td class="text-center">
                                    <a asp-action="Approve" asp-route-id="@item.RegistrationId" class="btn btn-sm btn-success">
                                        <i class="fa fa-check"></i> DuyГЎВ»вҖЎt
                                    </a>
                                    <a asp-action="Reject" asp-route-id="@item.RegistrationId" class="btn btn-sm btn-danger ms-2" onclick="return confirm('BГЎВәВЎn cГғВі chГЎВәВҜc chГЎВәВҜn muГЎВ»вҖҳn tГЎВ»В« chГЎВ»вҖҳi Г„вҖҳГ„Ж’ng kГғВҪ nГғВ y?');">
                                        <i class="fa fa-times"></i> TГЎВ»В« chГЎВ»вҖҳi
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">
                                <em>KhГғВҙng cГғВі Г„вҖҳГ„Ж’ng kГғВҪ nГғВ o Г„вҖҳang chГЎВ»Вқ duyГЎВ»вҖЎt.</em>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

