@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Bảng điều khiển";
}

<!-- Header -->
<div class="mb-4 p-4 text-white rounded shadow" style="background: linear-gradient(135deg, #4e73df, #224abe);">
    <h3>📊 Bảng điều khiển quản trị</h3>
    <p class="mb-0">Chào mừng bạn quay lại hệ thống 👋</p>
</div>

<!-- Cards thống kê -->
<div class="row g-3">

    <div class="col-md-3">
        <div class="card shadow-sm text-center p-3 border-0">
            <div class="fs-1">🍽️</div>
            <h6>Tổng quán ăn</h6>
            <h3 class="text-primary">@(ViewBag.TotalRestaurants ?? 0)</h3>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm text-center p-3 border-0">
            <div class="fs-1">⏳</div>
            <h6>Chờ duyệt</h6>
            <h3 class="text-warning">@(ViewBag.PendingRestaurants ?? 0)</h3>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm text-center p-3 border-0">
            <div class="fs-1">✅</div>
            <h6>Đã duyệt</h6>
            <h3 class="text-success">@(ViewBag.ApprovedRestaurants ?? 0)</h3>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm text-center p-3 border-0">
            <div class="fs-1">👨‍🍳</div>
            <h6>Chủ quán</h6>
            <h3 class="text-danger">@(ViewBag.TotalOwners ?? 0)</h3>
        </div>
    </div>

</div>

