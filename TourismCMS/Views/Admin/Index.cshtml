<h2>📊 Admin Dashboard</h2>

<div class="row mt-4">

    <div class="col-md-4">
        <div class="card p-3 shadow">
            <h5>Tổng quán</h5>
            <h3>@ViewBag.Total</h3>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-3 shadow">
            <h5>Chờ duyệt</h5>
            <h3>@ViewBag.Pending</h3>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-3 shadow">
            <h5>Đã duyệt</h5>
            <h3>@ViewBag.Approved</h3>
        </div>
    </div>

</div>