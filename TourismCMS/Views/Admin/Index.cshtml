@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Bảng điều khiển";
    ViewData["PageHeaderIcon"] = "📊";
    ViewData["PageHeaderTitle"] = "Bảng điều khiển quản trị";
    ViewData["PageHeaderSubtitle"] = "Chào mừng bạn quay lại hệ thống 👋";
}

@await Html.PartialAsync("_AdminPageHeader")

<!-- Cards thống kê -->
<div class="row g-3">

    <div class="col-md-3">
        <div class="card shadow-sm text-center p-3 border-0">
            <div class="fs-1">🍽️</div>
            <h6>Tổng quán ăn</h6>
            <h3 class="text-primary">@(ViewBag.TotalRestaurants ?? 0)</h3>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm text-center p-3 border-0">
            <div class="fs-1">⏳</div>
            <h6>Chờ duyệt</h6>
            <h3 class="text-warning">@(ViewBag.PendingRestaurants ?? 0)</h3>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm text-center p-3 border-0">
            <div class="fs-1">✅</div>
            <h6>Đã duyệt</h6>
            <h3 class="text-success">@(ViewBag.ApprovedRestaurants ?? 0)</h3>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm text-center p-3 border-0">
            <div class="fs-1">👨‍🍳</div>
            <h6>Chủ quán</h6>
            <h3 class="text-danger">@(ViewBag.TotalOwners ?? 0)</h3>
        </div>
    </div>

</div>


