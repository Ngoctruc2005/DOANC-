@model List<TourismCMS.Models.DeviceVisitViewModel>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Chi tiết lượt truy cập";
}

@await Html.PartialAsync("_AdminPageHeader")

<h5>Quán: <a asp-controller="POIs" asp-action="Details" asp-route-id="@ViewBag.PoiId">@ViewBag.PoiName</a></h5>

<div class="card mt-2">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Thời gian</th>
                        <th>Tên thiết bị</th>
                    </tr>
                </thead>
                <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="4" class="text-center text-muted">Không có dữ liệu</td></tr>
                }
                else
                {
                    @foreach (var v in Model)
                    {
                        <tr>
                            <td>@(v.VisitTime?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                            <td class="text-break">
                                <div class="fw-semibold">
                                    <a asp-action="DeviceDetails" asp-controller="Admin" asp-route-id="@System.Net.WebUtility.UrlEncode(v.RawDeviceId ?? string.Empty)">
                                        @Html.Raw(System.Net.WebUtility.HtmlEncode(v.DeviceAgent ?? "-"))
                                    </a>
                                </div>
                                <div class="text-muted small mt-1"><code>@Html.Raw(System.Net.WebUtility.HtmlEncode(v.RawDeviceId ?? "-"))</code></div>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>