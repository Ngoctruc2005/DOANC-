@model TourismCMS.Models.DevicesPageViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Danh sách thiết bị";
}

@await Html.PartialAsync("_AdminPageHeader")

<div class="d-flex align-items-center mb-2">
    <div>
        <h5 class="mb-0">Báo cáo thiết bị</h5>
    </div>
</div>

<!-- Active devices -->
<div class="card mb-3" id="activeDevicesContainerCard">
    <div class="card-body">
        <h6>Thiết bị đang hoạt động (@((Model?.ActiveDeviceCount) ?? 0))</h6>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Tên thiết bị</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.ActiveDevices == null || Model.ActiveDevices.Count == 0)
                {
                    <tr><td class="text-center text-muted">Không có thiết bị đang hoạt động</td></tr>
                }
                else
                {
                    @foreach (var d in Model.ActiveDevices)
                    {
                        <tr>
                            <td class="text-break">
                                <div class="fw-semibold">@Html.Raw(System.Net.WebUtility.HtmlEncode(d.AgentSample ?? "-"))</div>
                                <div class="text-muted small mt-1"><code>@Html.Raw(System.Net.WebUtility.HtmlEncode(d.DeviceId ?? "-"))</code></div>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
@* Partial removed — keep only the first (central) table. The card above has id 'activeDevicesContainerCard' so SignalR can replace it. *@

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js" integrity="" crossorigin="anonymous"></script>
    <script>
        (function(){
            const conn = new signalR.HubConnectionBuilder().withUrl('/devicehub').build();
            conn.on('DeviceListChanged', function(activeCount){
                // if server sent active count, update header immediately
                try {
                    const container = document.getElementById('activeDevicesContainerCard');
                    if (typeof activeCount !== 'undefined' && container) {
                        const h6 = container.querySelector('h6');
                        if (h6) h6.textContent = `Thiết bị đang hoạt động (${activeCount})`;
                    }
                } catch (e) { /* ignore */ }

                // refresh only the active devices partial
                fetch('/Admin/DevicesActivePartial')
                    .then(r => r.text())
                    .then(html => {
                        const container = document.getElementById('activeDevicesContainerCard');
                        if (container) {
                            container.outerHTML = html;
                        } else {
                            location.reload();
                        }
                    }).catch(()=>{ location.reload(); });
            });
            conn.start().catch(()=>{});
        })();
    </script>
}

<!-- End of view -->
