@model List<TourismCMS.Models.VisitHistoryItemViewModel>

@{
    Layout = "~/Views/Shared/_Sidebar.cshtml";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Lịch sử sử dụng";
    ViewData["PageHeaderIcon"] = "📈";
    ViewData["PageHeaderTitle"] = "Lịch sử sử dụng";
    ViewData["PageHeaderSubtitle"] = "Thống kê lượt truy cập các quán của bạn";

    var totalVisits = Model.Sum(x => x.TotalVisits);
    var totalRestaurants = Model.Count;
}
   

@await Html.PartialAsync("_OwnerPageHeader")

<div class="row g-3 mb-3">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-3 text-center">
            <h6>Tổng lượt truy cập</h6>
            <h3 class="text-primary">@totalVisits</h3>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-3 text-center">
            <h6>Quán của bạn có truy cập</h6>
            <h3 class="text-success">@totalRestaurants</h3>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <h5 class="mb-3">Biểu đồ lượt truy cập theo quán ăn</h5>
        @if (Model.Any())
        {
            <canvas id="visitByRestaurantChart" height="110"></canvas>
        }
        else
        {
            <p class="text-muted mb-0">Chưa có dữ liệu để hiển thị biểu đồ.</p>
        }
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Quán ăn</th>
                        <th>Địa chỉ</th>
                        <th>Lượt truy cập</th>
                        <th>Lần truy cập gần nhất</th>
                    </tr>
                </thead>
                <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted">Chưa có lượt truy cập từ app.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <a asp-controller="POIs" asp-action="Details" asp-route-id="@item.Poiid">@item.PoiName</a>
                            </td>
                            <td>@item.Address</td>
                            <td><span class="badge bg-primary">@item.TotalVisits</span></td>
                            <td>@(item.LastVisitTime?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>

@if (Model.Any())
{
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const chartLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(x => x.PoiName ?? "(Không tên)").ToList()));
        const chartData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(x => x.TotalVisits).ToList()));

        const chartCtx = document.getElementById('visitByRestaurantChart');
        if (chartCtx) {
            new Chart(chartCtx, {
                type: 'bar',
                data: {
                    labels: chartLabels,
                    datasets: [{
                        label: 'Lượt truy cập',
                        data: chartData,
                        backgroundColor: 'rgba(54, 162, 235, 0.6)',
                        borderColor: 'rgba(54, 162, 235, 1)',
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                precision: 0
                            }
                        }
                    }
                }
            });
        }
    </script>
}
    </div>
</div>
