<h2>? ThÍm qu·n (Owner)</h2>

<form id="createPoiForm" enctype="multipart/form-data">

    <input name="Name" placeholder="TÍn qu·n" class="form-control mb-2" required />

    <textarea name="Description" placeholder="MÙ t?" class="form-control mb-2"></textarea>

    <!-- Upload nhi?u ?nh -->
    <input type="file" name="Images" class="form-control mb-2" multiple />

    <!-- GPS -->
    <input type="hidden" name="Latitude" id="Latitude" />
    <input type="hidden" name="Longitude" id="Longitude" />

    <button class="btn btn-success">Luu</button>
</form>

<script>
    // ?? L?y v? trÌ GPS
    navigator.geolocation.getCurrentPosition(function(pos) {
        document.getElementById("Latitude").value = pos.coords.latitude;
        document.getElementById("Longitude").value = pos.coords.longitude;
    });

    document.getElementById("createPoiForm").addEventListener("submit", async function(e) {
        e.preventDefault();

        const formData = new FormData(this);
        const token = localStorage.getItem("token");

        const res = await fetch("http://localhost:8000/poi", {
            method: "POST",
            headers: {
                "Authorization": "Bearer " + token
            },
            body: formData
        });

        const data = await res.json();
        alert(data.message);
    });
</script>
