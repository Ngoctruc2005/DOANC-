@model List<POI>

<h2>Quán của tôi</h2>

<a href="/Owner/Create" class="btn btn-success mb-3">+ Thêm quán</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Tên</th>
            <th>Trạng thái</th>
            <th>Hành động</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            var poiKey = p.Poiid;
            <tr>
                <td>@p.Name</td>
                <td>
                    @if (p.Status == "Chờ duyệt")
                    {
                        <span class="badge bg-warning">Chờ duyệt</span>
                    }
                    else if (p.Status == "Open" || p.Status == "Đã duyệt")
                    {
                        <span class="badge bg-success">Đã duyệt</span>
                    }
                    else if (p.Status == "Đã bị admin xóa" || p.Status == "Đã xóa")
                    {
                        <span class="badge bg-danger">Đã bị xóa</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">@p.Status</span>
                    }
                </td>
                <td>
                    <a class="btn btn-info btn-sm" asp-controller="POIs" asp-action="Details" asp-route-id="@poiKey">Chi ti&#7871;t</a>
                    <a class="btn btn-warning btn-sm" asp-controller="POIs" asp-action="Edit" asp-route-id="@poiKey">S&#7917;a</a>
                    <a class="btn btn-danger btn-sm" asp-controller="POIs" asp-action="Delete" asp-route-id="@poiKey">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>

