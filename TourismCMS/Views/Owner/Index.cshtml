<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Dashboard Ch&#7911; Qu&#225;n</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

    <style>
            body {
                background: #f4f6f9;
                font-family: Arial;
            }

            .header {
                background: linear-gradient(135deg, #ff7e5f, #feb47b);
                color: white;
                padding: 25px;
                margin-bottom: 20px;
            }

            .card-custom {
                border: none;
                transition: 0.3s;
            }

                .card-custom:hover {
                    transform: translateY(-5px);
                    box-shadow: 0 8px 20px rgba(0,0,0,0.1);
                }

            .card-icon {
                font-size: 30px;
                margin-bottom: 10px;
            }

            .btn-custom {
                width: 100%;
            }
    </style>
</head>

<body>

    <div class="container mt-4">

        <!-- Header -->
        <div class="header text-center">
            <h2><i class="fa fa-gauge-high me-2"></i>Dashboard Ch&#7911; Qu&#225;n</h2>
            <p>Ch&#224;o m&#7915;ng b&#7841;n quay tr&#7903; l&#7841;i!</p>
        </div>

        <!-- Chức năng -->
        <div class="row">
            <div class="col-md-6 mb-3">
                <div class="card card-custom p-4 shadow-sm text-center">
                    <i class="fa fa-store card-icon text-primary"></i>
                    <h5>Qu&#7843;n l&#253; qu&#225;n</h5>
                    <p>Xem, s&#7917;a, x&#243;a th&#244;ng tin qu&#225;n &#259;n c&#7911;a b&#7841;n</p>
                    <a href="/POIs/Index" class="btn btn-primary btn-custom">
                        <i class="fa fa-list"></i> Qu&#7843;n l&#253; qu&#225;n
                    </a>
                </div>
            </div>

            <div class="col-md-6 mb-3">
                <div class="card card-custom p-4 shadow-sm text-center">
                    <i class="fa fa-plus-circle card-icon text-success"></i>
                    <h5>Th&#234;m qu&#225;n m&#7899;i</h5>
                    <p>T&#7841;o qu&#225;n &#259;n m&#7899;i &#273;&#7875; hi&#7875;n th&#7883; tr&#234;n h&#7879; th&#7889;ng</p>
                    <a href="/POIs/Create" class="btn btn-success btn-custom">
                        <i class="fa fa-plus"></i> Th&#234;m qu&#225;n
                    </a>
                </div>
            </div>

            <div class="col-md-6 mb-3">
                <div class="card card-custom p-4 shadow-sm text-center">
                    <i class="fa fa-chart-column card-icon text-warning"></i>
                    <h5>Lịch sử sử dụng</h5>
                    <p>Xem thống kê lượt truy cập các quán ăn của bạn từ app</p>
                    <a href="/Owner/VisitHistory" class="btn btn-warning btn-custom text-white">
                        <i class="fa fa-clock-rotate-left"></i> Xem lịch sử
                    </a>
                </div>
            </div>
        </div>

    </div>

</body>
</html>
