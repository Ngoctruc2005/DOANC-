@using System.Linq
@model IEnumerable<TourismCMS.Models.POI>

@{
    ViewData["Title"] = "Qu?n l˝ qu·n an";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>?? Qu?n l˝ qu·n an Vinh Kh·nh <small class="text-muted">- Admin</small></h2>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <a class="btn btn-success" asp-action="Create">+ ThÍm qu·n</a>
        <span class="badge bg-secondary ms-2">@Model?.Count() ?? 0</span>
    </div>

    <div class="d-flex">
        <input id="globalSearch" class="form-control form-control-sm" style="width:280px;" placeholder="TÏm theo tÍn ho?c mÙ t?..." />
    </div>
</div>

<div class="table-responsive">
    <table id="poisTable" class="table table-bordered table-hover nowrap" style="width:100%">
        <thead class="table-dark">
            <tr>
                <th>TÍn qu·n</th>
                <th>MÙ t?</th>
                <th>V? trÌ</th>
                <th>B·n kÌnh</th>
                <th>?nh</th>
                <th>Audio</th>
                <th>H‡nh d?ng</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><b>@item.Name</b></td>

                    <td style="max-width:300px; white-space:normal;">
                        @(string.IsNullOrEmpty(item.Description) ? "-" : (item.Description.Length > 80 ? item.Description.Substring(0, 80) + "..." : item.Description))
                    </td>

                    <td>
                        ?? @item.Latitude , @item.Longitude
                    </td>


                    <td>
                    </td>

                    <td>
                        {
                            <audio controls style="width:160px;">
                            </audio>
                        }
                        else
                        {
                            <span class="text-muted">KhÙng cÛ</span>
                        }
                    </td>

                    <td>
                        <a class="btn btn-warning btn-sm me-1" asp-action="Edit" asp-route-id="@item.Id">S?a</a>
                        <a class="btn btn-info btn-sm me-1" asp-action="Details" asp-route-id="@item.Id">Xem</a>
                        <a href="#" class="btn btn-danger btn-sm btn-delete" data-delete-url="@Url.Action("Delete", new { id = item.Id })" data-name="@item.Name">XÛa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Delete confirmation modal -->
<div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-labelledby="confirmDeleteLabel" aria-hidden="true">
  <div class="modal-dialog modal-sm modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="confirmDeleteLabel">X·c nh?n xÛa</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <!-- dynamically filled -->
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">H?y</button>
        <button type="button" id="confirmDeleteConfirm" class="btn btn-danger btn-sm">XÛa</button>
      </div>
    </div>
  </div>
</div>

@section Scripts {
    <!-- DataTables & jQuery (CDN fallbacks) -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

    <script>
        $(document).ready(function () {
            var table = $('#poisTable').DataTable({
                responsive: true,
                columnDefs: [
                    { orderable: false, targets: [4,5,6] }
                ],
                pageLength: 10
            });

            // global search box
            $('#globalSearch').on('keyup', function () {
                table.search(this.value).draw();
            });

            // delete button -> show modal
            var deleteUrl = null;
            $('.btn-delete').on('click', function (e) {
                e.preventDefault();
                deleteUrl = $(this).data('delete-url');
                var name = $(this).data('name') || 'm?c n‡y';
                $('#confirmDeleteModal .modal-body').text('B?n cÛ ch?c mu?n xÛa "' + name + '"?');
                var modal = new bootstrap.Modal(document.getElementById('confirmDeleteModal'));
                modal.show();
            });

            $('#confirmDeleteConfirm').on('click', function () {
                if (deleteUrl) {
                    // redirect to delete action (keeps existing controller behavior)
                    window.location.href = deleteUrl;
                }
            });
        });
    </script>
}
