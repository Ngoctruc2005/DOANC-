@model IEnumerable<TourismCMS.Models.POI>

@{
    if (ViewData["Layout"] != null)
    {
        Layout = ViewData["Layout"].ToString();
    }

    if (ViewData["Title"] == null)
    {
        ViewData["Title"] = "Danh sách quán ăn";
    }
}

<h1>@ViewData["Title"]</h1>

@if (!User.IsInRole("admin"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary"><i class="fa fa-plus"></i> Đăng ký quán mới</a>
    </p>
}

<!-- Thêm div để hiển thị bản đồ -->
<div id="map" style="height: 400px; width: 100%; margin-bottom: 20px;"></div>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Description)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Latitude)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Longitude)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Radius)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ImagePath)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.AudioPath)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Description)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Latitude)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Longitude)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Radius)
            </td>
            <td>
                @if(item.Status == "Đã duyệt" || string.IsNullOrEmpty(item.Status) || item.Status == "Open")
                {
                    <span class="badge bg-success">Open</span>
                }
                else if (item.Status == "Chờ duyệt")
                {
                    <span class="badge bg-warning text-dark">@item.Status</span>
                }
                else if (item.Status == "Đã xóa")
                {
                    <span class="badge bg-danger">@item.Status</span>
                }
                else
                {
                    <span class="badge bg-secondary">@item.Status</span>
                }
            </td>
            <td>
                @if (!string.IsNullOrEmpty(item.ImagePath))
                {
                    <img src="@item.ImagePath" alt="@item.Name" style="max-width: 100px; max-height: 100px; object-fit: cover;" />
                }
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.AudioPath)
            </td>
            <td>
                @if (ViewData["Title"]?.ToString() != "Danh sách chờ duyệt")
                {
                    <a class="btn btn-warning btn-sm me-1" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                    <a class="btn btn-info btn-sm me-1" asp-action="Details" asp-route-id="@item.Id">Details</a>
                    <a class="btn btn-danger btn-sm me-1" asp-action="Delete" asp-route-id="@item.Id">Delete</a>

                    @if (User.IsInRole("admin") && item.Status == "Chờ duyệt")
                    {

                    }
                }

                @if (User.IsInRole("admin") && item.Status == "Chờ duyệt")
                {
                    <form asp-action="Approve" method="post" style="display:inline;">
                        <input type="hidden" name="id" value="@item.Id" />
                        <button type="submit" class="btn btn-sm btn-success">Duyệt</button>
                    </form>
                    <span>|</span>
                    <form asp-action="Reject" method="post" style="display:inline;" onsubmit="return confirm('Bạn có chắc chắn muốn hủy yêu cầu duyệt này không?');">
                        <input type="hidden" name="id" value="@item.Id" />
                        <button type="submit" class="btn btn-sm btn-danger">Hủy</button>
                    </form>
                }
            </td>
        </tr>
}
    </tbody>
</table>

@section Scripts {
    <!-- Thư viện Leaflet CSS & JS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Khởi tạo bản đồ, set view mặc định (có thể thay đổi tọa độ trung tâm)
            var map = L.map('map').setView([10.762622, 106.660172], 10); // Ví dụ tọa độ TP.HCM

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);

            // Mảng chứa các POI được truyền từ Model
            var pois = [
                @foreach (var item in Model)
                {
                    // Lấy tất cả các điểm có tọa độ để hiển thị trên bản đồ quản lý
                    if ((item.Status != "Chờ duyệt") && (item.Status != "Đã xóa") && item.Latitude.HasValue && item.Longitude.HasValue)
                    {
                        <text>
                        {
                            name: "@Html.Raw(item.Name?.Replace("\"", "\\\""))",
                            lat: @item.Latitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture),
                            lng: @item.Longitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture),
                            url: '@Url.Action("Details", "POIs", new { id = item.Id })'
                        },
                        </text>
                    }
                }
            ];

            // Thêm marker cho từng POI
            var bounds = [];
            pois.forEach(function (poi) {
                var marker = L.marker([poi.lat, poi.lng]).addTo(map);
                marker.bindPopup(`<b>${poi.name}</b><br><a href="${poi.url}">Xem chi tiết</a>`);
                bounds.push([poi.lat, poi.lng]);
            });

            // Tự động zoom bản đồ cho vừa với tất cả các marker
            if (bounds.length > 0) {
                map.fitBounds(bounds);
            }
        });
    </script>
}
