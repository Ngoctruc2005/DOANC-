@model IEnumerable<TourismCMS.Models.POI>

@{
    var isPendingPage = string.Equals(
        ViewContext.RouteData.Values["action"]?.ToString(),
        "Pending",
        StringComparison.OrdinalIgnoreCase);
    var isApprovedPage = string.Equals(
        ViewContext.RouteData.Values["action"]?.ToString(),
        "Approved",
        StringComparison.OrdinalIgnoreCase);

    bool IsPendingStatus(string? status)
    {
        if (string.IsNullOrWhiteSpace(status)) return false;
        var s = status.Trim();
        return s.Equals("Chờ duyệt", StringComparison.OrdinalIgnoreCase)
            || s.Equals("Ch? duy?t", StringComparison.OrdinalIgnoreCase)
            || s.Equals("Cho duyet", StringComparison.OrdinalIgnoreCase);
    }

    bool IsDeletedStatus(string? status)
    {
        if (string.IsNullOrWhiteSpace(status)) return false;
        var s = status.Trim();
        return s.Equals("Đã xóa", StringComparison.OrdinalIgnoreCase)
            || s.Equals("?ã xóa", StringComparison.OrdinalIgnoreCase)
            || s.Equals("Ðã xóa", StringComparison.OrdinalIgnoreCase)
            || s.Equals("Đã bị admin xóa", StringComparison.OrdinalIgnoreCase)
            || s.Equals("Da b? admin xóa", StringComparison.OrdinalIgnoreCase);
    }

    bool IsCanceledStatus(string? status)
    {
        if (string.IsNullOrWhiteSpace(status)) return false;
        var s = status.Trim();
        return s.Equals("Đã hủy", StringComparison.OrdinalIgnoreCase)
            || s.Equals("?ã h?y", StringComparison.OrdinalIgnoreCase)
            || s.Equals("Ðã h?y", StringComparison.OrdinalIgnoreCase)
            || s.Equals("Ðã hủy", StringComparison.OrdinalIgnoreCase)
            || s.Equals("Da h?y", StringComparison.OrdinalIgnoreCase);
    }

    bool IsApprovedStatus(string? status)
    {
        if (string.IsNullOrWhiteSpace(status)) return true;
        var s = status.Trim();
        return s.Equals("Open", StringComparison.OrdinalIgnoreCase)
            || s.Equals("Approved", StringComparison.OrdinalIgnoreCase)
            || s.Equals("?ã duy?t", StringComparison.OrdinalIgnoreCase)
            || s.Equals("Ðã duy?t", StringComparison.OrdinalIgnoreCase)
            || s.Equals("Ðã duy?t", StringComparison.OrdinalIgnoreCase);
    }

    bool IsOpenStatus(string? status)
    {
        if (string.IsNullOrWhiteSpace(status)) return false;
        return status.Trim().Equals("Open", StringComparison.OrdinalIgnoreCase);
    }

    bool ShouldShowOnMap(POI item)
    {
        if (!item.Latitude.HasValue || !item.Longitude.HasValue)
        {
            return false;
        }

        if (User.IsInRole("admin") && isPendingPage)
        {
            return true;
        }

        if (IsDeletedStatus(item.Status) || IsCanceledStatus(item.Status))
        {
            return false;
        }

        if (User.IsInRole("poi_owner"))
        {
            return true;
        }

        if (User.IsInRole("admin") && isApprovedPage)
        {
            return IsApprovedStatus(item.Status) && !IsPendingStatus(item.Status);
        }

        if (User.IsInRole("admin") && !isPendingPage)
        {
            return IsOpenStatus(item.Status);
        }

        return IsApprovedStatus(item.Status) && !IsPendingStatus(item.Status);
    }

    if (ViewData["Layout"] is string layoutValue && !string.IsNullOrWhiteSpace(layoutValue))
    {
        Layout = layoutValue;
    }

    if (ViewData["Title"] == null)
    {
        ViewData["Title"] = "Danh sách quán ăn";
    }

    var mapPois = Model
        .Where(ShouldShowOnMap)
        .Select(item => new
        {
            name = item.Name ?? string.Empty,
            lat = item.Latitude!.Value,
            lng = item.Longitude!.Value,
            url = Url.Action("Details", "POIs", new { id = item.Poiid }) ?? "#"
        })
        .ToList();

    var visiblePois = User.IsInRole("poi_owner")
        ? Model.ToList()
        : Model
            .Where(item => !IsDeletedStatus(item.Status) && !IsCanceledStatus(item.Status))
            .ToList();
}

<h1>@ViewData["Title"]</h1>

@if (!User.IsInRole("admin"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary"><i class="fa fa-plus"></i> Đăng ký quán mới</a>
    </p>
}

<!-- Thêm div d? hi?n th? b?n d? -->
<div id="map" style="height: 400px; width: 100%; margin-bottom: 20px;"></div>

<table class="table">
    <thead>
        <tr>
            <th>Tên quán</th>
            <th>Mô tả</th>
            <th>Vĩ độ</th>
            <th>Kinh độ</th>
            <th>Địa chỉ</th>
            <th>Trạng thái</th>
            <th>Ảnh</th>
            <th>Khác</th>
            <th>Hành động</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in visiblePois) {
        var poiKey = item.Poiid;
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Description)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Latitude)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Longitude)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Address)
            </td>
            <td>
                @{ 
                    var raw = item.Status?.Trim() ?? string.Empty;
                    var statusText = raw;
                    var statusClass = "bg-secondary";

                    if (IsApprovedStatus(item.Status) || raw.Equals("Open", StringComparison.OrdinalIgnoreCase))
                    {
                        statusText = "Đã duyệt";
                        statusClass = "bg-success";
                    }
                    else if (IsPendingStatus(item.Status))
                    {
                        statusText = "Chờ duyệt";
                        statusClass = "bg-warning text-dark";
                    }
                    else if (IsDeletedStatus(item.Status))
                    {
                        statusText = "Đã xóa";
                        statusClass = "bg-danger";
                    }
                    else if (IsCanceledStatus(item.Status))
                    {
                        statusText = "Đã hủy";
                        statusClass = "bg-danger";
                    }
                    else if (raw.Equals("Close", StringComparison.OrdinalIgnoreCase) || raw.Equals("Closed", StringComparison.OrdinalIgnoreCase))
                    {
                        statusText = "Đóng";
                        statusClass = "bg-secondary";
                    }
                }
                <span class="badge @statusClass">@statusText</span>
            </td>
            <td>
                @if (!string.IsNullOrEmpty(item.ImagePath))
                {
                    <img src="@item.ImagePath" alt="@item.Name" style="max-width: 100px; max-height: 100px; object-fit: cover;" />
                }
            </td>
            <td>
            </td>
            <td>
                @if (isPendingPage && User.IsInRole("admin"))
                {
                    <div class="d-inline-flex flex-column gap-2">
                        <form asp-action="Approve" method="post" class="m-0">
                            <input type="hidden" name="id" value="@poiKey" />
                            <button type="submit" class="btn btn-sm btn-success w-100">Duy&#7879;t</button>
                        </form>
                        <form asp-action="Reject" method="post" class="m-0" onsubmit="return confirm('Bạn có chắc chắn muốn từ chối yêu cầu duyệt này không?');">
                            <input type="hidden" name="id" value="@poiKey" />
                            <button type="submit" class="btn btn-sm btn-danger w-100">Từ chối</button>
                        </form>
                    </div>
                }
                else
                {
                    <div class="d-inline-flex flex-nowrap gap-1">
                        <a class="btn btn-warning btn-sm" style="min-width:72px" asp-action="Edit" asp-route-id="@poiKey">Sửa</a>
                        <a class="btn btn-info btn-sm" style="min-width:72px" asp-action="Details" asp-route-id="@poiKey">Chi tiết</a>
                        <a class="btn btn-danger btn-sm" style="min-width:72px" asp-action="Delete" asp-route-id="@poiKey">Xóa</a>
                    </div>
                }
            </td>
        </tr>
}
    </tbody>
</table>

@section Scripts {
    <!-- Thu vi?n Leaflet CSS & JS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Kh?i t?o b?n d?, set view m?c d?nh (có th? thay d?i t?a d? trung tâm)
            var map = L.map('map').setView([10.762622, 106.660172], 10); // Ví d? t?a d? TP.HCM

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);

            // M?ng ch?a các POI du?c truy?n t? Model
            var pois = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(mapPois));

            // Thêm marker cho t?ng POI
            var bounds = [];
            pois.forEach(function (poi) {
                var marker = L.marker([poi.lat, poi.lng]).addTo(map);
                marker.bindPopup(`<b>${poi.name}</b><br><a href="${poi.url}">Xem chi tiết</a>`);
                bounds.push([poi.lat, poi.lng]);
            });

            // T? d?ng zoom b?n d? cho v?a v?i t?t c? các marker
            if (bounds.length > 0) {
                map.fitBounds(bounds);
            }
        });
    </script>
}

