@model TourismCMS.Models.POI

@{
    ViewData["Title"] = "Create POI";
}

<h2>Create POI</h2>

<form asp-action="Create" enctype="multipart/form-data">

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>

    <div class="mb-3">
        <label asp-for="Latitude" class="form-label"></label>
        <input asp-for="Latitude" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Longitude" class="form-label"></label>
        <input asp-for="Longitude" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Address" class="form-label"></label>
        <input asp-for="Address" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Status" class="form-label"></label>
        <select asp-for="Status" class="form-control">
            <option value="Open">Open</option>
            <option value="Close">Close</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Tải ảnh lên (ImagePath)</label>
        <input type="file" name="ImageFile" class="form-control" accept="image/*" />
    </div>

    <div class="mb-3">
        <label asp-for="CreatedAt" class="form-label"></label>
        <input asp-for="CreatedAt" class="form-control" type="datetime-local" />
    </div>

    <button type="submit" class="btn btn-primary mt-2">
        Create
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Back
    </a>

</form>
