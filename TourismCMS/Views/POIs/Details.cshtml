@model TourismCMS.Models.POI

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>POI</h4>
    <hr />
    <!-- Thêm div để hiển thị bản đồ nhỏ cho POI này -->
    <div id="map" style="height: 300px; width: 100%; margin-bottom: 20px;"></div>

    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Latitude)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Latitude)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Longitude)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Longitude)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Radius)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Radius)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ImagePath)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ImagePath)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.AudioPath)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.AudioPath)
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    <!-- Thư viện Leaflet CSS & JS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            @if(Model != null && Model.Latitude.HasValue && Model.Longitude.HasValue)
            {
                <text>
                var lat = @Model.Latitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture);
                var lng = @Model.Longitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture);
                var map = L.map('map').setView([lat, lng], 13); // Zoom level 13

                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '&copy; OpenStreetMap contributors'
                }).addTo(map);

                var marker = L.marker([lat, lng]).addTo(map);
                marker.bindPopup(`<b>@Html.Raw(Model.Name?.Replace("\"", "\\\""))</b>`).openPopup();
                </text>
            }
            else
            {
                <text>
                // Thay thế bằng tọa độ mặc định nếu không có
                document.getElementById('map').innerHTML = '<p>Bản đồ chưa khả dụng: Không có vĩ độ/kinh độ</p>';
                </text>
            }
        });
    </script>
}
