@model TourismCMS.Models.POI

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>POI</h4>
    <hr />
    <!-- Thêm div d? hi?n th? b?n d? nh? cho POI này -->
    <div id="map" style="height: 300px; width: 100%; margin-bottom: 20px;"></div>

    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Latitude)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Latitude)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Longitude)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Longitude)
        </dd>
        <dt class = "col-sm-2">
        </dt>
        <dd class = "col-sm-10">
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ImagePath)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ImagePath)
        </dd>
        <dt class = "col-sm-2">
        </dt>
        <dd class = "col-sm-10">
        </dd>
    </dl>
</div>
<div>
    <a class="btn btn-warning me-2" asp-action="Edit" asp-route-id="@Model?.Id">Edit</a>
    <a class="btn btn-secondary" asp-action="Index">Back to List</a>

    <div class="mt-4">
        <h5>QR truy c?p</h5>
        <p>S? l??t truy c?p: <strong>@(ViewBag.VisitCount ?? 0)</strong></p>
        @if (!string.IsNullOrEmpty(ViewBag.VisitUrl as string))
        {
            <p>
                <img id="qrImage" src="" alt="QR code" style="width:200px;height:200px;" />
            </p>
            <p><small>Quét QR b?ng ?ng d?ng trên ?i?n tho?i. N?u QR không ho?t ??ng do l?i ch?ng ch?, th? m? liên k?t HTTP bên d??i.</small></p>
            <p>
                <a id="qrLink" href="@(ViewBag.VisitUrl)" target="_blank">M? liên k?t QR</a>
            </p>
            <script>
                (function() {
                    try {
                        var visitUrl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.VisitUrl ?? ""));
                        if (!visitUrl) return;

                        // If host is localhost or an IP, prefer http for LAN access to avoid cert errors
                        var url;
                        try { url = new URL(visitUrl); } catch (e) { url = null; }
                        var finalUrl = visitUrl;
                        if (url) {
                            var host = url.hostname;
                            var isIp = /^\d+\.\d+\.\d+\.\d+$/.test(host);
                            if (isIp || host === 'localhost') {
                                url.protocol = 'http:';
                                finalUrl = url.toString();
                            }
                        }

                        var qrApi = 'https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=' + encodeURIComponent(finalUrl);
                        document.getElementById('qrImage').src = qrApi;
                        document.getElementById('qrLink').href = finalUrl;
                    } catch (e) {
                        console && console.error(e);
                    }
                })();
            </script>
        }
    </div>
</div>

@section Scripts {
    <!-- Thu vi?n Leaflet CSS & JS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

    <!-- Leaflet Geocoder CSS & JS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet-control-geocoder/dist/Control.Geocoder.css" />
    <script src="https://unpkg.com/leaflet-control-geocoder/dist/Control.Geocoder.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var lat, lng;
            var map;
            var initialZoom;

            @if (Model != null && Model.Latitude.HasValue && Model.Longitude.HasValue)
            {
                <text>
                // Use POI's coordinates if available
                lat = @Model.Latitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture);
                lng = @Model.Longitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture);
                initialZoom = 15; // Zoom in closer for a specific point
                </text>
            }
            else
            {
                <text>
                // Default to a central location in Vietnam if no coordinates are available
                lat = 16.047079; // Da Nang
                lng = 108.206230;
                initialZoom = 6; // Broader view of Vietnam
                </text>
            }

            map = L.map('map').setView([lat, lng], initialZoom);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);

            // Add marker for the POI if coordinates are available
            @if (Model != null && Model.Latitude.HasValue && Model.Longitude.HasValue)
            {
                <text>
                var marker = L.marker([lat, lng]).addTo(map);
                marker.bindPopup(`<b>@Html.Raw(Model.Name?.Replace("\"", "\\\""))</b>`).openPopup();
                </text>
            }

            // Add Geocoder control for address search
            L.Control.geocoder({
                defaultMarkGeocode: true, // Mark the geocoded address on the map
                placeholder: 'Nh?p ??a ch? ?? tìm ki?m...',
                errorMessage: 'Không tìm th?y ??a ch?.'
            }).addTo(map);
        });
    </script>
}

