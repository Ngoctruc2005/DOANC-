@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quan4 Culinary Tourism</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            font-family: Arial, sans-serif;
        }
        .hero {
            background: url('https://images.unsplash.com/photo-1504674900247-0877df9cc836') center/cover;
            color: white;
            height: 90vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
        }
        .hero-overlay {
            background: rgba(0,0,0,0.5);
            padding: 40px;
            border-radius: 10px;
        }
        .section {
            padding: 60px 20px;
        }
        .card img {
            height: 200px;
            object-fit: cover;
        }
    </style>
</head>
<body>

<!-- HEADER -->
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand" href="#">🍜 Quan4 Culinary</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="nav">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item"><a class="nav-link" href="#">Home</a></li>
                <li class="nav-item"><a class="nav-link" href="#map">Khám phá</a></li>
                <li class="nav-item"><a class="nav-link" href="#owner">Owner</a></li>
                <li class="nav-item"><a class="nav-link" href="#">Đăng nhập</a></li>
            </ul>
        </div>
    </div>
</nav>

<!-- HERO -->
<section class="hero">
    <div class="hero-overlay">
        <h1>🍜 Khám phá ẩm thực Quận 4</h1>
        <p>Bản đồ thông minh - Audio hướng dẫn - Offline PWA</p>
        <a href="#map" class="btn btn-warning mt-3">Bắt đầu khám phá</a>
    </div>
</section>

<!-- MAP PREVIEW -->
<section id="map" class="section text-center">
    <h2>🗺️ Bản đồ nổi bật</h2>
    <p>Xem nhanh các quán ăn nổi tiếng</p>
    <div class="container">
        <div class="bg-light p-5 rounded">
            <p>(Bản đồ sẽ được hiển thị tại đây - tích hợp MapLibre)</p>
        </div>
    </div>
</section>

<!-- POI LIST -->
<section class="section bg-light text-center">
    <h2>🍜 Quán ăn nổi bật</h2>
    <div class="container">
        <div class="row">

            <div class="col-md-4">
                <div class="card">
                    <img src="https://images.unsplash.com/photo-1550547660-d9450f859349" class="card-img-top">
                    <div class="card-body">
                        <h5>Quán 1</h5>
                        <p>Mô tả ngắn về quán ăn.</p>
                        <a href="#" class="btn btn-primary">Xem chi tiết</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card">
                    <img src="https://images.unsplash.com/photo-1551782450-a2132b4ba21d" class="card-img-top">
                    <div class="card-body">
                        <h5>Quán 2</h5>
                        <p>Mô tả ngắn về quán ăn.</p>
                        <a href="#" class="btn btn-primary">Xem chi tiết</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card">
                    <img src="https://images.unsplash.com/photo-1504674900247-0877df9cc836" class="card-img-top">
                    <div class="card-body">
                        <h5>Quán 3</h5>
                        <p>Mô tả ngắn về quán ăn.</p>
                        <a href="#" class="btn btn-primary">Xem chi tiết</a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- OWNER -->
<section id="owner" class="section text-center">
    <h2>🏪 Bạn là chủ quán?</h2>
    <p>Đăng ký để đưa quán của bạn lên hệ thống</p>
    <a href="#" class="btn btn-success">Đăng ký Owner</a>
</section>

<!-- FEATURES -->
<section class="section bg-light text-center">
    <h2>✨ Tính năng nổi bật</h2>
    <div class="container">
        <div class="row">
            <div class="col-md-3">🎧 Audio tự động</div>
            <div class="col-md-3">📍 GPS & Geofence</div>
            <div class="col-md-3">📴 Offline</div>
            <div class="col-md-3">🤖 AI gợi ý</div>
        </div>
    </div>
</section>

<!-- FOOTER -->
<footer class="bg-dark text-white text-center p-3">
    <p>©Quan4 Culinary Tourism</p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>