@{
    ViewData["Title"] = "\u0110\u0103ng Nh\u1EADp Ch\u1EE7 Qu\u00E1n";
    Layout = "_Layout";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white text-center">
                <h4 class="mb-0">&#272;&#259;ng Nh&#7853;p D&#224;nh Cho Ch&#7911; Qu&#225;n</h4>
            </div>
            <div class="card-body">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">
                        @ViewBag.Error
                    </div>
                }

                <form method="post" asp-controller="Auth" asp-action="Login">
                    <div class="form-group mb-3">
                        <label class="form-label" for="username">T&#234;n &#273;&#259;ng nh&#7853;p / Username</label>
                        <input type="text" id="username" name="username" class="form-control" required placeholder="Nh&#7853;p t&#234;n &#273;&#259;ng nh&#7853;p" />
                    </div>
                    <div class="form-group mb-4">
                        <label class="form-label" for="password">M&#7853;t kh&#7849;u / Password</label>
                        <input type="password" id="password" name="password" class="form-control" required placeholder="Nh&#7853;p m&#7853;t kh&#7849;u" />
                    </div>
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg">&#272;&#259;ng Nh&#7853;p</button>
                    </div>
                </form>

                <div class="text-center mt-3">
                    B&#7841;n ch&#432;a c&#243; t&#224;i kho&#7843;n ch&#7911; qu&#225;n? <br />
                    <a href="/Auth/Register" class="text-decoration-none">&#272;&#259;ng k&#253; t&#224;i kho&#7843;n ngay</a>
                    <hr />
                    <a href="/Auth/AdminLogin" class="text-secondary text-decoration-none"><small>&#272;&#259;ng nh&#7853;p v&#7899;i t&#432; c&#225;ch Qu&#7843;n Tr&#7883; Vi&#234;n</small></a>
                </div>
            </div>
        </div>
    </div>
</div>
