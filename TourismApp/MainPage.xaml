<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourismApp.MainPage"
             BackgroundColor="#F5F5F5">

    <VerticalStackLayout Padding="20" Spacing="15">

        <!-- Tiêu đề -->
        <Label Text="🍜 Tourism App"
               FontSize="28"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               TextColor="DarkRed"/>

        <!-- 🌍 CHỌN NGÔN NGỮ -->
        <Label Text="🌍 Chọn ngôn ngữ" FontAttributes="Bold"/>

        <Picker x:Name="languagePicker" Title="Ngôn ngữ">
            <Picker.Items>
                <x:String>vi</x:String>
                <x:String>en</x:String>
            </Picker.Items>
        </Picker>

        <!-- 🔊 NÚT PHÁT THUYẾT MINH -->
        <Button Text="🔊 Nghe thuyết minh"
                BackgroundColor="#4CAF50"
                TextColor="White"
                Clicked="OnSpeakClicked"/>

        <!-- 🗺️ NÚT MAP -->
        <Button Text="🗺️ Xem bản đồ"
                Clicked="OnOpenMapClicked"
                BackgroundColor="#2196F3"
                TextColor="White"/>

        <!-- ❤️ FAVORITE -->
        <Button Text="❤️ Yêu thích"
                Clicked="OnOpenFavoriteClicked"
                BackgroundColor="#E91E63"
                TextColor="White"/>

    </VerticalStackLayout>

</ContentPage>