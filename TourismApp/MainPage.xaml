<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourismApp.MainPage"
             BackgroundColor="#F5F5F5">

    <VerticalStackLayout Padding="30" Spacing="25" VerticalOptions="Center">

        <!-- Tiêu đề -->
        <Label Text="🍜 Tourism App"
               FontSize="32"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               TextColor="#D32F2F"/>

        <!-- 🌍 CHỌN NGÔN NGỮ -->
        <Frame Padding="15" CornerRadius="15" BackgroundColor="White" HasShadow="True" BorderColor="Transparent">
            <VerticalStackLayout Spacing="10">
                <Label Text="{Binding [SelectLanguage]}" FontAttributes="Bold" TextColor="#333" FontSize="16"/>
                <Picker x:Name="languagePicker" Title="{Binding [SelectLanguage]}" TextColor="#555">
                    <Picker.Items>
                        <x:String>vi</x:String>
                        <x:String>en</x:String>
                    </Picker.Items>
                </Picker>
            </VerticalStackLayout>
        </Frame>

        <!-- NÚT TƯƠNG TÁC -->
        <VerticalStackLayout Spacing="15" Margin="0,10,0,0">
            <!-- 🔊 NÚT PHÁT THUYẾT MINH -->
            <Button Text="{Binding [ListenAudio]}"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    HeightRequest="50"
                    Clicked="OnSpeakClicked"/>

            <!-- 🗺️ NÚT MAP -->
            <Button Text="{Binding [ViewMap]}"
                    Clicked="OnOpenMapClicked"
                    BackgroundColor="#2196F3"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    HeightRequest="50"/>

            <!-- ❤️ FAVORITE -->
            <Button Text="{Binding [Favorites]}"
                    Clicked="OnOpenFavoriteClicked"
                    BackgroundColor="#E91E63"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    HeightRequest="50"/>
        </VerticalStackLayout>

    </VerticalStackLayout>

</ContentPage>