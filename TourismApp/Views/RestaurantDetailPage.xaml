<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="TourismApp.Views.RestaurantDetailPage"
    Title="Chi tiết quán">

    <ScrollView>

        <VerticalStackLayout Padding="20" Spacing="15">

            <Label x:Name="nameLabel"
                   FontSize="24"
                   FontAttributes="Bold"/>

            <HorizontalStackLayout Spacing="15">
                <Button x:Name="btnPlayAudio" 
                        Text="{Binding [ListenAudio]}" 
                        Clicked="OnPlayAudioClicked" />

                <Button x:Name="btnDirections"
                        Text="Chỉ đường"
                        Clicked="OnDirectionsClicked" 
                        BackgroundColor="Green"
                        TextColor="White" />
            </HorizontalStackLayout>

            <Label x:Name="descriptionLabel"
                   FontSize="16"/>

            <Label Text="{Binding [Menu]}"
                   FontAttributes="Bold"
                   FontSize="18"/>

            <CollectionView x:Name="menuList">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="LightGray" StrokeShape="RoundRectangle 10" Padding="10" Margin="0,5">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="{Binding ItemName}" FontAttributes="Bold" FontSize="16" VerticalOptions="Center"/>
                                <Label Grid.Column="1" Text="{Binding Price, StringFormat='{0:N0} đ'}" TextColor="Red" FontSize="16" VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>