<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourismApp.Views.SettingsPage">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Tiêu đề -->
            <Label Text="{Binding [SettingsTitle]}"
                   FontSize="24"
                   HorizontalOptions="Center"/>

            <!-- Chọn ngôn ngữ -->
            <Frame Padding="10" CornerRadius="10">
                <VerticalStackLayout Spacing="10">

                    <Label Text="{Binding [SelectLanguage]}" />

                    <Picker x:Name="languagePicker" Title="{Binding [SelectLanguage]}">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>Tiếng Việt (vi)</x:String>
                                <x:String>English (en)</x:String>
                                <x:String>中文 (zh)</x:String>
                                <x:String>日本語 (ja)</x:String>
                                <x:String>한국어 (ko)</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>

                </VerticalStackLayout>
            </Frame>

            <!-- Nút lưu -->
            <Button Text="{Binding [SaveSettings]}"
                    Clicked="OnSaveClicked"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>