<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourismApp.Views.SettingsPage">

    <ScrollView BackgroundColor="#F5F5F5">
        <VerticalStackLayout Padding="20" Spacing="25">

            <!-- Chọn ngôn ngữ -->
            <Border Padding="20" StrokeShape="RoundRectangle 15" BackgroundColor="White" Stroke="Transparent">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Opacity="0.1" Radius="5" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="15">

                    <Label Text="{Binding [SelectLanguage]}" FontAttributes="Bold" TextColor="#333" FontSize="16"/>

                    <Picker x:Name="languagePicker" Title="{Binding [SelectLanguage]}" TextColor="#555">
                        <Picker.Items>
                            <x:String>Tiếng Việt (vi)</x:String>
                            <x:String>English (en)</x:String>
                            <x:String>中文 (zh)</x:String>
                            <x:String>日本語 (ja)</x:String>
                            <x:String>한국어 (ko)</x:String>
                        </Picker.Items>
                    </Picker>

                </VerticalStackLayout>
            </Border>
            <Border Padding="20" StrokeShape="RoundRectangle 15" BackgroundColor="White" Stroke="Transparent">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Opacity="0.1" Radius="5" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="15">

                    <Label Text="API Base URL" FontAttributes="Bold" TextColor="#333" FontSize="16"/>

                    <Entry x:Name="apiBaseUrlEntry"
                           Placeholder="http://10.0.2.2:5219/api/"
                           Keyboard="Url"
                           TextColor="#555"/>

                </VerticalStackLayout>
            </Border>

            <!-- Nút lưu -->
            <Button Text="{Binding [SaveSettings]}"
                    Clicked="OnSaveClicked"
                    BackgroundColor="#2196F3"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    HeightRequest="50"
                    Margin="0,10,0,0"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>



