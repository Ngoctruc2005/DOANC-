<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourismApp.Views.FavoritePage">

    <StackLayout>

        <!-- Tiêu đề -->
        <Label Text="❤️ Danh sách yêu thích"
               FontSize="20"
               HorizontalOptions="Center"
               Margin="10"/>

        <!-- Danh sách quán -->
        <CollectionView x:Name="list">

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Frame Margin="10" Padding="10" CornerRadius="10">
                        <StackLayout>

                            <!-- ✅ CHỈ GIỮ LẠI TÊN QUÁN -->
                            <Label Text="{Binding Name}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"/>

                        </StackLayout>
                    </Frame>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </StackLayout>

</ContentPage>