<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourismApp.Views.FavoritePage">

    <StackLayout>

        <!-- Tiêu đề -->
        <Label Text="{Binding [FavoriteListTitle]}"
               FontSize="20"
               HorizontalOptions="Center"
               Margin="10"/>

        <!-- Danh sách quán -->
        <CollectionView x:Name="list" SelectionMode="None">

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Frame Margin="10,5,10,5" Padding="10" CornerRadius="10">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer CommandParameter="{Binding .}" Tapped="OnRestaurantTapped" />
                        </Frame.GestureRecognizers>
                        <Grid ColumnDefinitions="*, Auto">

                            <!-- TÊN QUÁN -->
                            <Label Grid.Column="0" 
                                   Text="{Binding Name}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center"
                                   VerticalTextAlignment="Center"/>

                            <!-- NÚT XÓA -->
                            <Button Grid.Column="1" 
                                    Text="🗑️ Xóa" 
                                    TextColor="White"
                                    BackgroundColor="#FF3B30"
                                    Padding="10,5"
                                    CornerRadius="5"
                                    HeightRequest="40"
                                    CommandParameter="{Binding .}"
                                    Clicked="OnDeleteClicked"/>

                        </Grid>
                    </Frame>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </StackLayout>

</ContentPage>