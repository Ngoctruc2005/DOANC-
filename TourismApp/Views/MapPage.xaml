<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
    x:Class="TourismApp.Views.MapPage">

    <Grid>

        <!-- MAP -->
        <maps:Map 
            x:Name="map"
            MapType="Street"
            IsShowingUser="False" />

        <!-- PANEL -->
        <Border 
            x:Name="detailPanel"
            BackgroundColor="White"
            StrokeShape="RoundRectangle 20"
            Padding="15"
            VerticalOptions="End"
            Margin="10"
            IsVisible="False">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Opacity="0.2" Radius="5" />
            </Border.Shadow>

            <VerticalStackLayout Spacing="10">

                <Label 
                    x:Name="nameLabel"
                    FontSize="20"
                    FontAttributes="Bold"
                    TextColor="Black" />

                <Label 
                    x:Name="descLabel"
                    FontSize="14"
                    TextColor="Gray" />

                <Label 
                    x:Name="bestSellerLabel"
                    FontSize="14"
                    TextColor="Orange" />

                <Button 
                    Text="?? Yêu thích"
                    Clicked="OnFavoriteClicked"/>

                <Button 
                    Text="Ðóng"
                    Clicked="OnCloseClicked"/>
                <Button Text="?? Nghe thuyết minh"
        Clicked="OnPlayAudio"/>
            </VerticalStackLayout>

        </Border>

    </Grid>

</ContentPage>