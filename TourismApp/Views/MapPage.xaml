<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
    x:Class="TourismApp.Views.MapPage"
    BackgroundColor="White">

    <Grid>

        <!-- 🗺️ MAP -->
        <maps:Map 
            x:Name="map"
            MapType="Street"
            IsShowingUser="True" />

        <!-- 📄 DETAIL PANEL -->
        <Frame 
    x:Name="detailPanel"
    BackgroundColor="#FFFFFFDD"
    CornerRadius="25"
    Padding="15"
    HasShadow="True"
    VerticalOptions="End"
    Margin="10"
    IsVisible="False"
    HeightRequest="350">

            <Grid>

                <!-- Nội dung chính -->
                <ScrollView>
                    <VerticalStackLayout Spacing="10">

                        <!-- 🌐 Ngôn ngữ -->
                        <Picker x:Name="languagePicker"
        Title="Ngôn ngữ"
        IsVisible="False"
        SelectedIndexChanged="OnLanguageChanged">
                            <Picker.Items>
                                <x:String>vi</x:String>
                                <x:String>en</x:String>
                            </Picker.Items>
                        </Picker>

                        <!-- Tên quán -->
                        <Label x:Name="nameLabel"
                       FontSize="22"
                       FontAttributes="Bold"/>

                        <!-- Mô tả -->
                        <Label x:Name="descLabel"
                       FontSize="14"
                       TextColor="Gray"
                       LineBreakMode="WordWrap"/>

                        <!-- Món nổi bật -->
                        <Label x:Name="bestSellerLabel"
                       FontSize="14"
                       TextColor="DarkOrange"/>

                        <!-- Menu -->
                        <CollectionView x:Name="menuList" HeightRequest="80">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Label Text="{Binding .}" FontSize="14"/>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <!-- Nút -->
                        <HorizontalStackLayout Spacing="10">
                            <Button Text="❤️ Yêu thích"
                            BackgroundColor="#FF7043"
                            TextColor="White"
                            CornerRadius="10"
                            Clicked="OnFavoriteClicked"/>

                            <Button Text="🔊 Nghe"
                            BackgroundColor="#FFD700"
                            TextColor="Black"
                            CornerRadius="10"
                            Clicked="OnPlayAudioClicked"/>
                        </HorizontalStackLayout>

                    </VerticalStackLayout>
                </ScrollView>

                <!-- ❌ Nút đóng (dấu X) -->
                <Button Text="x"
                BackgroundColor="Transparent"
                TextColor="Black"
                FontSize="18"
                WidthRequest="30"
                HeightRequest="30"
                HorizontalOptions="End"
                VerticalOptions="Start"
                Clicked="OnCloseClicked"/>

            </Grid>
        </Frame>
    </Grid>
</ContentPage>