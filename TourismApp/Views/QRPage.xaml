<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="TourismApp.Views.QRPage">

    <Grid RowDefinitions="*,Auto" RowSpacing="12" Padding="12">

        <!-- Grid chứa Camera và khung lưới đè lên -->
        <Grid Grid.Row="0">
            <ContentView
                x:Name="cameraHost" />

            <!-- Khung vuông định vị vùng quét -->
            <Border WidthRequest="260"
                    HeightRequest="260"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Stroke="#FFD700"
                    StrokeThickness="4"
                    BackgroundColor="Transparent">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>

                <!-- Vạch ngang mờ mô phỏng tia laser -->
                <BoxView x:Name="scanLine"
                         HeightRequest="3"
                         BackgroundColor="#CCFFD700"
                         VerticalOptions="Start"
                         HorizontalOptions="Fill" />
            </Border>
        </Grid>

        <Label
            x:Name="resultLabel"
            Grid.Row="1"
            Text="{Binding [ScanQRInstruction]}"
            HorizontalOptions="Center"
            FontSize="16" />

    </Grid>

</ContentPage>